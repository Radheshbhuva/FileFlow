# Server Configuration
PORT=5000
NODE_ENV=development

# Security & CORS
CLIENT_URL=http://localhost:5173
JWT_SECRET=super_secret_fileflow_key_for_development
JWT_EXPIRES_IN=1d

# AWS Configuration (Future compatibility)
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
DYNAMODB_TABLE_NAME=FileFlowMetadata
S3_BUCKET_NAME=fileflow-storage-dev
